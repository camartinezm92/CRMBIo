# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Drive Integration (Service Account)
# GOOGLE_SERVICE_ACCOUNT_EMAIL: The email from your JSON credentials file
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# GOOGLE_PRIVATE_KEY: The "private_key" string from your JSON file (include beginning/end markers)
GOOGLE_PRIVATE_KEY=""
# GOOGLE_DRIVE_FOLDER_ID: The ID of the folder shared with the service account
GOOGLE_DRIVE_FOLDER_ID=""
# GOOGLE_ADMIN_EMAIL: The email (e.g. ingeniero@ucihonda.com.co) that will receive notifications
GOOGLE_ADMIN_EMAIL=""
# SMTP_USER: Your full gmail address (e.g. alerts@ucihonda.com.co)
SMTP_USER=""
# SMTP_PASS: An 'App Password' generated in Google Security settings
SMTP_PASS=""

# WHATSAPP_TOKEN: Permanent access token from Meta Developers
WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID: ID from your WhatsApp Cloud API setup
WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID: The Business Account ID from Meta
WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_ADMIN_PHONE: Your phone number with country code (e.g. 573138182815)
WHATSAPP_ADMIN_PHONE=""

# Google Sheets Configuration
GOOGLE_SHEETS_INVENTORY_ID=""
